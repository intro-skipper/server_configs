*.intro-skipper.org intro-skipper.org {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
	}
	log {
		output discard
	}

	vars {
		default_version "10.11"
		commit_hash "d340f16ba1256ec563d7b08c0396645d555e65b8"
	}

	@discord host discord.intro-skipper.org
	redir @discord https://discord.gg/AYZ7RJ3BuA 308

	@github host fsn1.intro-skipper.org ams.intro-skipper.org fra.intro-skipper.org
	handle @github {
		@blocked {
			not path /{$GITHUB_HOOK}
		}
		@hook {
			path /{$GITHUB_HOOK}
		}
		abort @blocked
		handle @hook {
			rewrite /hook
			reverse_proxy 127.0.0.1:8080
		}
	}

	# 1) All supported versions: any 10.x or 12.x
	@ver {
		path /manifest.json
		header_regexp VER User-Agent ^Jellyfin-Server/(10\.\d+|12\.\d+)\..*$
	}
	redir @ver https://cdn.jsdelivr.net/gh/intro-skipper/manifest@{vars.commit_hash}/{http.regexp.VER.1}/manifest.json 302

	# 3a) Requests not for /manifest.json → GitHub
	@notManifest {
		not host fsn1.intro-skipper.org fra.intro-skipper.org ams.intro-skipper.org
		not path /manifest.json
	}
	redir @notManifest https://github.com/intro-skipper/ 308

	# 3b) /manifest.json but UA not Jellyfin-Server/* → GitHub
	@manifestNoJelly {
		path /manifest.json
		not header User-Agent Jellyfin-Server/*
	}
	redir @manifestNoJelly https://github.com/intro-skipper/ 308
}
